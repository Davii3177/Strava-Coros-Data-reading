# See README "Connecting Strava" — STRAVA_REFRESH_TOKEN is generated by
# src/strava_auth_server.py, not copied from strava.com/settings/api
# (that page only shows a read-only token; activity fetch needs activity:read_all).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# Fitbit data via the Google Health API (the successor to the legacy Fitbit
# Web API, which Google retires in September 2026). These are Google Cloud
# OAuth 2.0 credentials (…apps.googleusercontent.com), NOT a dev.fitbit.com
# app. GOOGLE_HEALTH_REFRESH_TOKEN is generated by src/fitbit_auth_server.py.
# See README "Connecting Fitbit (Google Health API)".
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REFRESH_TOKEN=

# Recommended, especially in deployed environments: an IANA timezone name
# (e.g. America/New_York, Europe/London) for the runner's actual location.
# Cloud hosts like Render run in UTC, and a server-local "today" rolls over
# hours before midnight where the runner actually is, which silently shows
# tomorrow's workout for the back half of the evening. Leave blank to fall
# back to the server's own local date/timezone (may be wrong on a host).
RUNNER_TIMEZONE=

# Password required before visitors can access the dashboard.
# It is used only as the first-account setup code after this upgrade.
APP_PASSWORD=

# Optional: lets an owner create additional accounts at /register.
REGISTRATION_CODE=

# Recommended in deployed environments so sessions survive app restarts.
FLASK_SECRET_KEY=

# Keep false for local http development. Set true on the HTTPS production host.
FLASK_COOKIE_SECURE=false

# Local fallback when DATABASE_URL is not set.
DATABASE_PATH=data/gaman.sqlite3

# Production PostgreSQL connection string. Render supplies this automatically
# from render.yaml; leave blank for local SQLite development.
DATABASE_URL=

# Optional: enables AI-expanded recovery education. Leave blank to use the
# built-in conservative guidance. These keys are read only on the server.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: enables the "Ask Gaman" chat assistant on the dashboard. Uses
# Google's Gemini API. Leave GEMINI_API_KEY blank to disable the feature
# (the chat then shows a friendly "not set up yet" message). Read only on
# the server; the runner's data is sent to Google only when Ask Gaman is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
